{
	"name": "n8n-nodes-unlimited-fallback-agent",
	"version": "1.0.2",
	"description": "A Gateway node for n8n AI Agent to support unlimited fallback chat models with Tool and Memory support.",
	"license": "MIT",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"langchain",
		"ai-agent",
		"fallback",
		"gateway"
	],
	"author": {
		"name": "Nexus Automation"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [],
		"nodes": [
			"dist/nodes/UnlimitedFallbackModel.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
