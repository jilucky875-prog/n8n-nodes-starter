{
	"name": "n8n-nodes-unlimited-fallback-agent",
	"version": "1.0.2",
	"description": "Gateway node for n8n AI Agent v3.1+ to support unlimited fallbacks with Tools & Memory.",
	"license": "MIT",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"ai-gateway",
		"fallback-llm"
	],
	"author": {
		"name": "Nexus Automation"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"nodes": [
			"dist/nodes/UnlimitedFallbackModel.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
